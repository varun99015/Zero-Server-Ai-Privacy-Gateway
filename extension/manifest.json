{
    "manifest_version": 3,
    "name": "Zero Server AI Gateway",
    "version": "1.0",
    "permissions": [
        "storage"
    ],
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "security/vault.js",
                "security/attestation.js",
                "content/content.js"
            ]
        }
    ]
}